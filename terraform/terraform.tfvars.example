# terraform.tfvars.example
# Copy this file to terraform.tfvars and fill in YOUR values.
# terraform.tfvars is gitignored -- never commit your real values.

# AWS region where everything is deployed.
aws_region = "eu-north-1"

# Globally unique S3 bucket name. Pick something specific to you.
# Must be lowercase, no spaces, hyphens OK, no underscores.
# Example: "yourname-react-s3-cloudfront-demo"
s3_bucket_name = "REPLACE-WITH-YOUR-UNIQUE-BUCKET-NAME"

# Optional: name of the IAM user GitHub Actions will use to deploy.
# iam_user_name = "github-actions-react-s3-cloudfront"

# Optional: tags applied to every resource.
# tags = {
#   Project   = "react-s3-cloudfront-demo"
#   ManagedBy = "Terraform"
#   Owner     = "your-name"
# }
